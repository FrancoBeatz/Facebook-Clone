rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Email verification check (allows both Google and standard logged-in users during development).
    function isVerifiedUser() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() 
                    && isValidId(userId) 
                    && userId == request.auth.uid
                    && incoming().uid == request.auth.uid
                    && incoming().createdAt is string && incoming().createdAt.size() <= 45;
      allow update: if isSignedIn()
                    && userId == request.auth.uid
                    && incoming().uid == existing().uid
                    && incoming().createdAt == existing().createdAt;
    }

    // 3. Posts Collection
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser()
                    && isValidId(postId)
                    && incoming().postId == postId
                    && incoming().authorId == request.auth.uid
                    && incoming().commentsCount == 0
                    && incoming().createdAt is string && incoming().createdAt.size() <= 45;
      allow update: if isVerifiedUser()
                    && (
                      // Action: Edit Post by original author
                      (existing().authorId == request.auth.uid 
                       && incoming().authorId == request.auth.uid 
                       && incoming().postId == existing().postId 
                       && incoming().createdAt == existing().createdAt 
                       && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'images', 'updatedAt'])) ||
                      // Action: Like/Unlike Post (any user can modify likes)
                      (incoming().authorId == existing().authorId 
                       && incoming().postId == existing().postId 
                       && incoming().createdAt == existing().createdAt 
                       && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) ||
                      // Action: Modify commentsCount
                      (incoming().authorId == existing().authorId 
                       && incoming().postId == existing().postId 
                       && incoming().createdAt == existing().createdAt 
                       && incoming().diff(existing()).affectedKeys().hasOnly(['commentsCount']))
                    );
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }

    // 4. Comments Subcollection
    match /posts/{postId}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser()
                    && isValidId(commentId)
                    && incoming().commentId == commentId
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt is string && incoming().createdAt.size() <= 45;
      allow update: if false;
      allow delete: if isSignedIn() 
                    && (existing().userId == request.auth.uid 
                        || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
    }

    // 5. Chat Rooms Collection
    match /chats/{roomId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isVerifiedUser()
                    && isValidId(roomId)
                    && (request.auth.uid in incoming().participants);
      allow update: if isSignedIn()
                    && (request.auth.uid in existing().participants)
                    && incoming().participants == existing().participants
                    && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'typing'])
                    );
      allow delete: if false;
    }

    // 6. Messages within Chat Rooms
    match /chats/{roomId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants);
      allow create: if isVerifiedUser()
                    && isValidId(messageId)
                    && (request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants)
                    && incoming().senderId == request.auth.uid
                    && incoming().messageId == messageId
                    && incoming().createdAt is string && incoming().createdAt.size() <= 45;
      allow update: if isSignedIn()
                    && (request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants)
                    && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['reactions', 'seenBy'])
                    );
      allow delete: if false;
    }

    // 7. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.receiverId == request.auth.uid;
      allow create: if isVerifiedUser()
                    && isValidId(notificationId)
                    && incoming().senderId == request.auth.uid
                    && incoming().id == notificationId
                    && incoming().createdAt is string && incoming().createdAt.size() <= 45;
      allow update: if isSignedIn()
                    && existing().receiverId == request.auth.uid
                    && incoming().receiverId == existing().receiverId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && existing().receiverId == request.auth.uid;
    }

    // 8. Relationships / Friends Collection
    match /relationships/{relId} {
      allow read: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isVerifiedUser()
                    && isValidId(relId)
                    && incoming().id == relId
                    && incoming().fromId == request.auth.uid
                    && incoming().status == 'requested'
                    && incoming().createdAt is string && incoming().createdAt.size() <= 45;
      allow update: if isSignedIn()
                    && existing().toId == request.auth.uid
                    && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
                    && incoming().status == 'friends';
      allow delete: if isSignedIn() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid);
    }

    // Helper: Admin Check
    function isPlatformAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 9. Groups Collection
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidId(groupId);
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isPlatformAdmin());
    }

    // 10. Business Pages Collection
    match /pages/{pageId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidId(pageId);
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isPlatformAdmin());
    }

    // 11. Saved Bookmarks Collection
    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerifiedUser() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 12. Reported Content Collection
    match /reports/{reportId} {
      allow read, update: if isPlatformAdmin();
      allow create: if isVerifiedUser() && incoming().reporterId == request.auth.uid;
      allow delete: if isPlatformAdmin();
    }

    // 13. Story Highlights Collection
    match /highlights/{highlightId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() 
                    && isValidId(highlightId)
                    && incoming().id == highlightId
                    && incoming().userId == request.auth.uid
                    && incoming().postIds is list
                    && incoming().postIds.size() <= 20
                    && incoming().createdAt is string && incoming().createdAt.size() <= 45;
      allow update: if isVerifiedUser()
                    && existing().userId == request.auth.uid
                    && incoming().userId == request.auth.uid
                    && incoming().id == existing().id
                    && incoming().createdAt == existing().createdAt
                    && incoming().postIds is list
                    && incoming().postIds.size() <= 20
                    && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'coverColor', 'postIds']);
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isPlatformAdmin());
    }
  }
}
